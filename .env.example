# ============================
# PostgreSQL Configuration
# ============================
POSTGRES_DB=acoustic_monitor
POSTGRES_USER=acoustic_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================
# Audio Processing
# ============================
AUDIO_SAMPLE_RATE=44100
RECORD_DURATION_SECONDS=30
RECORD_INTERVAL_SECONDS=300

# ============================
# Detection Settings
# ============================
BIRD_CONFIDENCE_THRESHOLD=0.7

# ============================
# Cloudflare Tokens
# ============================
CLOUDFLARE_TUNNEL_TOKEN=xyz

# ============================
# Station Information
# ============================
STATION_NAME=Munich Balcony
STATION_DESCRIPTION=Prototype deployment
STATION_COUNTRY=Germany
STATION_REGION=Bavaria
STATION_LATITUDE=0.00000
STATION_LONGITUDE=0.00000